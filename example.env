# ── Local development ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/planme
MONGO_TEST_URI=mongodb://127.0.0.1:27017/planme_test
PORT=5001
COOKIE_SECRET=change-me
NODE_ENV=development
LOG_LEVEL=info
MAX_SESSIONS_PER_USER=3

# ── Email / SMTP (leave blank in dev — reset link returned in API response instead) ──
# Brevo: smtp-relay.brevo.com / 587 / your Brevo login email / SMTP key from dashboard
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@planme.app

# ── Auth strategy switches ────────────────────────────────────────
# Set to "false" to disable a strategy; any other value (or absent) means enabled
AUTH_LOCAL_ENABLED=true
AUTH_GOOGLE_ENABLED=true

# ── Google OAuth ──────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# ── Production (Render) ───────────────────────────────────────────
# NODE_ENV=production
# MONGO_URI=<MongoDB Atlas connection string>
# COOKIE_SECRET=<random 32+ char secret — Render can generate this>
# PORT is set automatically by Render, do not override it
# LOG_LEVEL=info
# MAX_SESSIONS_PER_USER=3
#
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=<your Brevo login email>
# SMTP_PASS=<SMTP key from Brevo → SMTP & API → SMTP tab>
# SMTP_FROM=noreply@yourdomain.com
