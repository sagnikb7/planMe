{
  "name": "planme",
  "version": "0.9.0",
  "description": "Idea capture app — Express API + React frontend",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "concurrently \"pnpm --filter planme-server dev\" \"pnpm --filter client dev\"",
    "build": "pnpm --filter client build && pnpm --filter planme-server build",
    "start": "node server/dist/index.js",
    "prod:local": "pnpm build && NODE_ENV=production pnpm start",
    "test": "pnpm --filter planme-server test",
    "lint": "pnpm --filter client lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1"
    }
  }
}
